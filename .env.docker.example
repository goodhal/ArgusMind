# Docker Compose 环境变量样例
# 一键安装脚本首次运行时会复制为 .env，并自动生成 POSTGRES_PASSWORD / NEO4J_PASSWORD

# 持久化数据根目录（相对 docker-compose.yml 所在目录）
# 其下自动使用 postgres/、neo4j/、work/、repos/ 子目录
DATA_DIR=./data

# PostgreSQL（密码由 install 脚本随机生成）
POSTGRES_USER=argusmind
POSTGRES_PASSWORD=__AUTO_GENERATE__
POSTGRES_DB=argusmind

# Neo4j（密码由 install 脚本随机生成；勿含 / 等特殊字符）
NEO4J_USER=neo4j
NEO4J_PASSWORD=__AUTO_GENERATE__

# API 对外端口
ARGUSMIND_PORT=6066
