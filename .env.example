# ArgusMind 环境变量样例
# 只支持 neo4j / postgres 两类数据库配置；如未设置将回退到 config.yaml
# 其它配置（LLM / OpenCode 等）必须通过数据库 configs 表进行管理

# Neo4j
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=YourNeo4jPassword123!

# PostgreSQL
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=argusmind
POSTGRES_USER=argusmind
POSTGRES_PASSWORD=YourPgPassword123!

LOG_LEVEL=INFO
